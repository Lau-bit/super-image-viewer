{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Super Image Viewer",
  "version": "1.0.0",
  "identifier": "com.slaur.super-image-viewer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Super Image Viewer",
        "width": 1400,
        "height": 900,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": false,
        "backgroundColor": "#111111",
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: asset: http://asset.localhost blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
